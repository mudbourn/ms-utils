# Per-user trust baseline — never commit; each user generates their own
data/.ms_trusted_hash

# Per-user runtime settings
data/ms_settings.json
data/ms_settings_default.json
data/ms_theme.json

# Profile archives — change every time a profile switch happens;
# these are runtime state, not source files
profiles/

# Developer tool logs
data/ms_dev.log
data/guardian_agent.log

# Backup archives
backups/

# Hammerspoon Spoons (local installs)
Spoons/

# macOS
.DS_Store

# Key files — never commit
*.pem

# Compiled AHK binary and downloaded AHK libraries — not tracked
lib/WebView2.ahk
lib/WebView2/
lib/Jxon.ahk

# Development planning docs — not shipped
docs/WINDOWS_PORT_PLAN.md

# LLM agent instructions — not shipped
writing_style.txt
